# Configuration MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/online-store

# Configuration JWT
JWT_SECRET=your_very_secret_key_here_min_32_chars_recommended

# Authentification Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Configuration Facebook (optionnel)
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_TOKEN=your_facebook_access_token

# Configuration serveur
PORT=5000
NODE_ENV=development

# Logging (optionnel)
LOG_LEVEL=debug

# Rate Limiting (optionnel)
RATE_LIMIT_WHITELIST=127.0.0.1,::1
RATE_LIMIT_BLACKLIST=192.168.1.100,10.0.0.5
