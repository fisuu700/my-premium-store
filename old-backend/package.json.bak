    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "test:server": "node test-server.js",
    "test": "powershell -ExecutionPolicy Bypass -File test-endpoints.ps1"
  },
  "keywords": [
